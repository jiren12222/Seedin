body {
  margin: 0;
  font-family: system-ui;
  background: #0b0b0f;
  color: white;
}

.container {
  padding: 20px;
}

.nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.logo {
  font-weight: bold;
}

.btn {
  background: #1f1f2e;
  color: white;
  padding: 8px 12px;
  border-radius: 8px;
  text-decoration: none;
}

.hero {
  text-align: center;
  margin-top: 60px;
}

.hero h1 {
  font-size: 36px;
}

.actions {
  margin-top: 20px;
  display: flex;
  gap: 10px;
  justify-content: center;
}

.primary {
  background: #4f46e5;
  color: white;
  padding: 10px 14px;
  border-radius: 10px;
  text-decoration: none;
}

.secondary {
  background: #1f1f2e;
  color: white;
  padding: 10px 14px;
  border-radius: 10px;
  border: none;
}

.grid {
  margin-top: 40px;
  display: grid;
  gap: 10px;
}

.card {
  background: #151521;
  padding: 20px;
  border-radius: 12px;
}
